# Lobster Quant - Environment Configuration
# Copy this file to .env and customize

# Application
DEBUG=false
LOG_LEVEL=INFO

# Market Configuration
ENABLE_US_STOCK=true
ENABLE_HK_STOCK=true
ENABLE_A_STOCK=false

# Data Configuration
DATA_YEARS=3
DATA_CACHE_DIR=./data/cache
DATA_CACHE_TTL=3600
DATA_TIMEOUT=10

# Data Providers
US_DATA_PROVIDER=yfinance
HK_DATA_PROVIDER=yfinance
A_DATA_PROVIDER=akshare

# Technical Indicator Parameters
MA_SHORT_PERIOD=20
MA_LONG_PERIOD=200
RSI_PERIOD=14
ATR_PERIOD=14
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9
BB_PERIOD=20
BB_STD=2.0

# Scoring Weights
SCORE_WEIGHT_TREND=0.40
SCORE_WEIGHT_MOMENTUM=0.20
SCORE_WEIGHT_VOLUME=0.15
SCORE_WEIGHT_PATTERN=0.25

# Backtest Parameters
BACKTEST_HOLDING_DAYS=20
BACKTEST_MIN_SCORE=20
BACKTEST_LOOKBACK_DAYS=500
BACKTEST_SLIPPAGE_PCT=0.001
BACKTEST_COMMISSION_PCT=0.001

# OFF Filter Parameters
OFF_VIX_THRESHOLD=35.0
OFF_ATR_PCT_THRESHOLD=0.05
OFF_GAP_THRESHOLD=0.08
OFF_MIN_VOLUME_RATIO=0.05
OFF_MA200_RECOVERY_DAYS=60

# Benchmark
BENCHMARK_SYMBOL=SPY
